# Turn on email alerts: copy this file to deploy/.env and fill in a SENDING
# account. docker compose auto-loads deploy/.env — no extra flags needed.
#
#   cp deploy/.env.example deploy/.env
#   # edit deploy/.env, then run the normal quickstart:
#   docker compose -f deploy/docker-compose.yml up --build
#
# Gmail: SMTP_PASS is a 16-char "App password" (NOT your normal password).
#   Google account -> Security -> 2-Step Verification -> App passwords -> generate.
# Any SMTP provider works (Gmail, Outlook, SendGrid, Mailgun, Resend, ...).
#
# Recipients are per-site: type an email in the "Add a website" form on the page.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_FROM=you@gmail.com
SMTP_PASS=your-16-char-app-password
