# Turn on email alerts: copy this file to deploy/.env and fill in a SENDING
# account. docker compose auto-loads deploy/.env — no extra flags needed.
#
#   cp deploy/.env.example deploy/.env
#   # edit deploy/.env, then run the normal quickstart:
#   docker compose -f deploy/docker-compose.yml up --build
#
# Gmail: SMTP_PASS is a 16-char "App password" (NOT your normal password).
#   Google account -> Security -> 2-Step Verification -> App passwords -> generate.
# Any SMTP provider works (Gmail, Outlook, SendGrid, Mailgun, Resend, ...).
#
# With just this filled in, every site alerts YOU (alerts default to SMTP_FROM).
# Want a specific site to also notify others? Add their emails in the "Add a
# website" form. Want a different default inbox? Set ALERT_EMAIL_TO.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_FROM=you@gmail.com
SMTP_PASS=your-16-char-app-password
# ALERT_EMAIL_TO=you@gmail.com

# The status page requires a user account (sign up on first visit) — no shared
# password to configure here.
