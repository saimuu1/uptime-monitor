# Copy to deploy/.env and fill in. deploy/.env is gitignored (your secret stays local).
# Gmail: SMTP_PASS is a 16-char "App password", NOT your normal password.
#   Google account -> Security -> 2-Step Verification -> App passwords -> generate.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=saimurali2009@gmail.com
SMTP_FROM=saimurali2009@gmail.com
SMTP_PASS=your-16-char-app-password
